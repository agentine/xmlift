{
  "name": "@agentine/xmlift",
  "version": "0.1.0",
  "description": "Modern, zero-dependency, TypeScript-first drop-in replacement for xml2js with security-by-default",
  "keywords": [
    "xml",
    "xml2js",
    "parser",
    "sax",
    "xml-parser",
    "builder",
    "typescript",
    "zero-dependency",
    "esm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/agentine/xmlift.git"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
